#!/bin/sh

# Ensure ~/.loomkin directory exists for database and config
LOOMKIN_HOME="${LOOMKIN_HOME:-$HOME/.loomkin}"
mkdir -p "$LOOMKIN_HOME"

# Set database path if not already set
export LOOMKIN_DB_PATH="${LOOMKIN_DB_PATH:-$LOOMKIN_HOME/loomkin.db}"

# Release cookie for distributed Erlang (not typically needed for Loomkin)
export RELEASE_COOKIE="${RELEASE_COOKIE:-loomkin_<%= @release.version %>}"
export RELEASE_DISTRIBUTION="${RELEASE_DISTRIBUTION:-none}"
