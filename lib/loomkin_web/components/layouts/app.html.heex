<a
  href="#main-content"
  class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[9999] focus:px-4 focus:py-2 focus:rounded focus:bg-brand focus:text-white focus:text-sm focus:font-medium"
>
  Skip to main content
</a>
<main>
  <.flash_group flash={assigns[:flash] || @flash} />
  <%= if assigns[:inner_content] do %>
    {@inner_content}
  <% else %>
    {render_slot(@inner_block)}
  <% end %>
</main>
